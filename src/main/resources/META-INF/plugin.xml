<idea-plugin>
    <id>com.codeprometheus.aialgohelper</id>
    <name>AI Algo Helper</name>
    <vendor email="zhouzixin@apache.org" url="https://github.com/CodePrometheus">Zixin Zhou · GitHub@CodePrometheus</vendor>

    <!-- version, description, change-notes and idea-version are injected by patchPluginXml at build time -->

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.jcef</depends>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity  implementation = "com.codeprometheus.aialgohelper.plugin.listener.RegisterPluginInstallerStateListener"/>
        <toolWindow id="AI Algo Helper" secondary="false" icon="AIAlgoHelperIcons.TOOL_WINDOW" anchor="left"
                    factoryClass="com.codeprometheus.aialgohelper.plugin.window.WindowFactory" />
        <toolWindow id="AI Algo Helper Console" secondary="false" icon="AIAlgoHelperIcons.TOOL_WINDOW" anchor="bottom"
                    factoryClass="com.codeprometheus.aialgohelper.plugin.window.ConsoleWindowFactory" />
        <applicationService serviceInterface="com.codeprometheus.aialgohelper.plugin.setting.PersistentConfig"
                            serviceImplementation="com.codeprometheus.aialgohelper.plugin.setting.PersistentConfig"/>
        <projectService serviceInterface="com.codeprometheus.aialgohelper.plugin.setting.ProjectConfig"
                        serviceImplementation="com.codeprometheus.aialgohelper.plugin.setting.ProjectConfig"/>
        <projectService serviceInterface="com.codeprometheus.aialgohelper.plugin.setting.StatisticsData"
                        serviceImplementation="com.codeprometheus.aialgohelper.plugin.setting.StatisticsData"/>
        <applicationConfigurable parentId="tools" displayName="AI Algo Helper" id="com.codeprometheus.aialgohelper.settings"
                                 instance="com.codeprometheus.aialgohelper.plugin.setting.SettingConfigurable"/>
        <statusBarWidgetFactory id="ai-algo-helper-TimerStatusBar" implementation="com.codeprometheus.aialgohelper.plugin.timer.TimerStatusBarWidgetProvider"/>
        <lang.foldingBuilder language="JAVA" implementationClass="com.codeprometheus.aialgohelper.plugin.language.ScopeFoldingBuilder"/>
        <lang.foldingBuilder language="Python" implementationClass="com.codeprometheus.aialgohelper.plugin.language.ScopeFoldingBuilder"/>
        <lang.foldingBuilder language="ObjectiveC" implementationClass="com.codeprometheus.aialgohelper.plugin.language.ScopeFoldingBuilder"/>
        <lang.foldingBuilder language="CS" implementationClass="com.codeprometheus.aialgohelper.plugin.language.ScopeFoldingBuilder"/>
        <!--<lang.foldingBuilder language="ECMAScript 6" implementationClass="com.codeprometheus.aialgohelper.plugin.language.ScopeFoldingBuilder"/>-->
        <lang.foldingBuilder language="ruby" implementationClass="com.codeprometheus.aialgohelper.plugin.language.ScopeFoldingBuilder"/>
        <lang.foldingBuilder language="Swift" implementationClass="com.codeprometheus.aialgohelper.plugin.language.ScopeFoldingBuilder"/>
        <lang.foldingBuilder language="go" implementationClass="com.codeprometheus.aialgohelper.plugin.language.ScopeFoldingBuilder"/>
        <lang.foldingBuilder language="Scala" implementationClass="com.codeprometheus.aialgohelper.plugin.language.ScopeFoldingBuilder"/>
        <lang.foldingBuilder language="kotlin" implementationClass="com.codeprometheus.aialgohelper.plugin.language.ScopeFoldingBuilder"/>
        <lang.foldingBuilder language="Renderscript" implementationClass="com.codeprometheus.aialgohelper.plugin.language.ScopeFoldingBuilder"/>
        <lang.foldingBuilder language="PHP" implementationClass="com.codeprometheus.aialgohelper.plugin.language.ScopeFoldingBuilder"/>
        <lang.foldingBuilder language="Shell Script" implementationClass="com.codeprometheus.aialgohelper.plugin.language.ScopeFoldingBuilder"/>
        <lang.foldingBuilder language="GenericSQL" implementationClass="com.codeprometheus.aialgohelper.plugin.language.ScopeFoldingBuilder"/>
        <lang.foldingBuilder language="TypeScript" implementationClass="com.codeprometheus.aialgohelper.plugin.language.ScopeFoldingBuilder"/>

        <fileEditorProvider implementation="com.codeprometheus.aialgohelper.plugin.editor.QuestionEditorProvider"/>
        <fileIconPatcher implementation="com.codeprometheus.aialgohelper.plugin.editor.QuestionEditorIconProvider" order="last"/>
        <editorTabTitleProvider implementation="com.codeprometheus.aialgohelper.plugin.editor.QuestionEditorTabTitleProvider"  order="last"/>

        <fileType name="lcvDoc" extensions="lcv;" fileNames=".lcv" language="lcvDoc"
                  implementationClass="com.codeprometheus.aialgohelper.plugin.editor.LCVFileType" fieldName="INSTANCE"/>
        <fileEditorProvider implementation="com.codeprometheus.aialgohelper.plugin.editor.LCVProvider"/>
        <httpRequestHandler implementation="com.codeprometheus.aialgohelper.plugin.editor.PreviewStaticServer"/>
        <postStartupActivity implementation="com.codeprometheus.aialgohelper.plugin.listener.SupportCheck"/>
    </extensions>

    <actions>
